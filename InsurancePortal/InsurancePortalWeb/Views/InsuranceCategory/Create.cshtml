@model InsuranceCategory // because we will be working with Category model

<form method="post">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary">Create Insurance Category</h2>
            <hr />
        </div>
        <div class="mb-3 row p-1">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="row">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </div>
        
    </div>
</form>